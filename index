<!-- Q6 — DIAGRAM: Supplementary angles -->
<div class="question no-break">
  <div class="qlabel">Question 6</div>
  <p>The diagram below shows two angles that together form a straight line.</p>

  <div class="diagwrap">
    <svg width="360" height="145" viewBox="0 0 360 145" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Two supplementary angles on a straight line. Left angle labeled (3x+15) degrees, right angle labeled 60 degrees. A ray extends upward from the vertex.">
      <!-- Straight horizontal line with arrows -->
      <line x1="22" y1="105" x2="338" y2="105" stroke="#222" stroke-width="2.5"/>
      <polygon points="22,105 35,99 35,111"  fill="#222"/>
      <polygon points="338,105 325,99 325,111" fill="#222"/>
      <!-- Ray from vertex at (180,105), going up-right at 60° from right horizontal -->
      <!-- endpoint: (180 + 90·cos60°, 105 − 90·sin60°) = (180+45, 105−77.9) = (225, 27) -->
      <line x1="180" y1="105" x2="225" y2="27" stroke="#222" stroke-width="2.5"/>
      <polygon points="225,27 216,42 228,39" fill="#222"/>
      <!-- Vertex dot -->
      <circle cx="180" cy="105" r="3.5" fill="#222"/>
      <!-- Arc indicating 60° angle (right side) — radius 28, from (208,105) sweeping CCW to point on ray -->
      <!-- Point on ray at dist 28: (180+28·0.5, 105−28·0.866)=(194, 81.8) -->
      <path d="M 208,105 A 28,28 0 0,0 194,81" fill="none" stroke="#555" stroke-width="1.8"/>
      <!-- Arc indicating (3x+15)° angle (left side) — just a small arc near vertex -->
      <path d="M 152,105 A 28,28 0 0,1 166,81" fill="none" stroke="#555" stroke-width="1.8"/>
      <!-- Labels -->
      <text x="210" y="101" font-family="Georgia,serif" font-size="15" fill="#222">60°</text>
      <text x="44"  y="96"  font-family="Georgia,serif" font-size="15" fill="#222">(3<tspan font-style="italic">x</tspan> + 15)°</text>
    </svg>
  </div>

  <p>What is the value of <em>x</em>?</p>
  <ol class="ch">
    <li data-l="A">5</li>
    <li data-l="B">15</li>
    <li data-l="C">35</li>
    <li data-l="D">120</li>
  </ol>
</div>
